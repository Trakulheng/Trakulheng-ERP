generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  manager
  staff
  viewer
}

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  name              String?
  password          String?
  pin               String?
  pinSetAt          DateTime?
  role              UserRole  @default(staff)
  emailVerified     Boolean   @default(false)
  employeeRecordId  String?
  branchIds         Json?
  accessStartDate   String?
  accessEndDate     String?
  consentAcceptedAt DateTime?
  consentVersion    String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  tokens   VerificationToken[]
  sessions Session[]
}

model VerificationToken {
  id        String   @id @default(cuid())
  token     String   @unique
  type      String   @default("email")
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Customer {
  id          String       @id @default(cuid())
  name        String
  contact     String?
  email       String?
  phone       String?
  type        String       @default("SME")
  status      String       @default("active")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  invoices    Invoice[]
  salesOrders SalesOrder[]
}

model Invoice {
  id         String   @id @default(cuid())
  number     String   @unique
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
  date       DateTime
  dueDate    DateTime
  amount     Float
  status     String   @default("pending")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Expense {
  id          String   @id @default(cuid())
  category    String
  description String
  date        DateTime
  amount      Float
  status      String   @default("pending")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Product {
  id        String   @id @default(cuid())
  sku       String   @unique
  name      String
  category  String
  stock     Int      @default(0)
  minStock  Int      @default(10)
  unitPrice Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Supplier {
  id             String          @id @default(cuid())
  name           String
  contact        String?
  email          String?
  phone          String?
  category       String?
  rating         Float           @default(0)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  purchaseOrders PurchaseOrder[]
}

model PurchaseOrder {
  id           String   @id @default(cuid())
  number       String   @unique
  supplierId   String
  supplier     Supplier @relation(fields: [supplierId], references: [id])
  date         DateTime
  expectedDate DateTime
  items        Int
  total        Float
  status       String   @default("pending")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model SalesOrder {
  id          String   @id @default(cuid())
  number      String   @unique
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id])
  date        DateTime
  items       Int
  amount      Float
  stage       String   @default("prospect")
  probability Int      @default(50)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Department {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model GeneralSetting {
  id        String   @id @default("singleton")
  data      Json
  updatedAt DateTime @updatedAt
}

model Brand {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  description String?
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model DashboardConfig {
  id        String   @id @default(cuid())
  role      String   @unique
  widgets   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Branch {
  id                  String   @id @default(cuid())
  code                String   @unique
  name                String
  brand               String?
  province            String?
  country             String   @default("Thailand")
  status              String   @default("active")
  isHeadOffice        Boolean  @default(false)
  address             String?
  googleMapsUrl       String?
  location            String?
  floor               String?
  sizeSqm             Float?
  phone               String?
  email               String?
  lineId              String?
  managerId           String?
  manager             String?
  startDate           String?
  assignedEmployees   Json?
  lat                 Float    @default(0)
  lng                 Float    @default(0)
  radiusMeters        Float    @default(200)
  rentFrom            String?
  rentTo              String?
  rentMonthly         Float?
  lessorName          String?
  lessorContactFirst  String?
  lessorContactLast   String?
  lessorContactTel    String?
  lessorContactEmail  String?
  lessorContactLineId String?
  rentalDocs          Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model Employee {
  id                String        @id @default(cuid())
  employeeId        String        @unique
  name              String
  firstName         String?
  lastName          String?
  firstNameTh       String?
  lastNameTh        String?
  nickname          String?
  gender            String        @default("male")
  dob               String?
  nationalId        String?
  phone             String?
  personalEmail     String?
  workEmail         String?
  department        String
  position          String
  employmentType    String        @default("full-time")
  branchId          String?
  branchIds         Json?
  hireDate          String?
  probationEndDate  String?
  managerId         String?
  salary            Float
  bankAccounts      Json?
  ssn               String?
  ssfFundType       String?
  ssfEnrollmentDate String?
  ssfHospital       String?
  ssfStatus         String?
  emergencyName     String?
  emergencyRelation String?
  emergencyPhone    String?
  photo             String?
  documents         Json?
  status            String        @default("active")
  verified          Boolean       @default(false)
  verifiedDate      String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  leaveRequests     LeaveRequest[]
}

model LeaveRequest {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])
  type       String
  fromDate   DateTime
  toDate     DateTime
  days       Int
  status     String   @default("pending")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model PayrollRun {
  id          String   @id @default(cuid())
  period      String
  employees   Int
  grossPay    Float
  deductions  Float
  netPay      Float
  status      String   @default("draft")
  processedAt DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TaskList {
  id        String   @id @default(cuid())
  name      String
  color     String   @default("blue")
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tasks     Task[]
}

model Task {
  id           String    @id @default(cuid())
  title        String
  description  String?
  dueDate      String?
  dueTime      String?
  priority     String    @default("medium")
  status       String    @default("pending")
  assigneeName String?
  shiftLabel   String?
  taskListId   String?
  taskList     TaskList? @relation(fields: [taskListId], references: [id], onDelete: SetNull)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([taskListId])
}

model ShiftAssignment {
  id            String   @id @default(cuid())
  branchId      String
  employeeId    String
  shiftId       String?
  date          String
  note          String?
  confirmStatus String   @default("pending")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([employeeId, date])
  @@index([branchId, date])
}

model RolePermission {
  id          String   @id @default(cuid())
  role        String   @unique
  permissions Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AttendanceRecord {
  id                 String   @id @default(cuid())
  branchId           String
  employeeId         String
  date               String
  shiftId            String?
  clockInTime        String?
  clockOutTime       String?
  clockInLat         Float?
  clockInLng         Float?
  clockInDistance    Float?
  clockOutLat        Float?
  clockOutLng        Float?
  clockOutDistance   Float?
  gpsValid           Boolean  @default(false)
  status             String   @default("not-yet")
  totalMinutes       Int?
  overtimeMinutes    Int?
  lateMinutes        Int?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([employeeId, date])
  @@index([branchId, date])
}

model ShiftChangeRequest {
  id               String    @id @default(cuid())
  branchId         String?
  employeeId       String
  date             String
  currentShiftId   String
  requestedShiftId String?
  reason           String
  status           String    @default("pending")
  resolvedBy       String?
  resolvedAt       DateTime?
  managerNote      String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([branchId])
  @@index([status])
}

model ShiftTemplate {
  id           String   @id @default(cuid())
  name         String
  code         String
  startTime    String
  endTime      String
  breakMinutes Int      @default(60)
  color        String   @default("blue")
  branchId     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([code, branchId])
}

model ShiftTodo {
  id              String         @id @default(cuid())
  shiftId         String
  name            String
  sequence        Int            @default(0)
  expectedMinutes Int            @default(30)
  photoRequired   Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  logs            ShiftTodoLog[]

  @@index([shiftId])
}

model ShiftTodoLog {
  id          String    @id @default(cuid())
  todoId      String
  todo        ShiftTodo @relation(fields: [todoId], references: [id], onDelete: Cascade)
  date        String
  employeeId  String
  completedAt DateTime?
  photoUrl    String?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([todoId, date, employeeId])
}
